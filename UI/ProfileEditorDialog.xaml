<Window x:Class="SoftScroll.UI.ProfileEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="640" Width="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}">
    <Window.Resources>
        <!-- Default dark theme colors (updated by code-behind) -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#252525"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B0B0B0"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#404040"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#333333"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtHeader" Grid.Row="0" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14"
                   TextTrimming="CharacterEllipsis"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>
                <CheckBox x:Name="ChkEnabled" Margin="0,0,0,16"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TxtLblStep" Grid.Row="0" Grid.Column="0" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtStep" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"
                             PreviewTextInput="NumericOnly" DataObject.Pasting="OnPasteNumeric"/>

                    <TextBlock x:Name="TxtLblAnim" Grid.Row="1" Grid.Column="0" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtAnim" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"
                             PreviewTextInput="NumericOnly" DataObject.Pasting="OnPasteNumeric"/>

                    <TextBlock x:Name="TxtLblAccelDelta" Grid.Row="2" Grid.Column="0" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtAccelDelta" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"
                             PreviewTextInput="NumericOnly" DataObject.Pasting="OnPasteNumeric"/>

                    <TextBlock x:Name="TxtLblAccelMax" Grid.Row="3" Grid.Column="0" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtAccelMax" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10"
                             PreviewTextInput="NumericOnly" DataObject.Pasting="OnPasteNumeric"/>

                    <TextBlock x:Name="TxtLblTail" Grid.Row="4" Grid.Column="0" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtTail" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"
                             PreviewTextInput="NumericOnly" DataObject.Pasting="OnPasteNumeric"/>

                    <TextBlock x:Name="TxtLblEasing" Grid.Row="5" Grid.Column="0" Margin="0,0,0,10"/>
                    <ComboBox x:Name="CmbEasing" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock x:Name="TxtLblHStep" Grid.Row="6" Grid.Column="0" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtHStep" Grid.Row="6" Grid.Column="1" Margin="0,0,0,10"
                             PreviewTextInput="NumericOnly" DataObject.Pasting="OnPasteNumeric"/>

                    <TextBlock x:Name="TxtLblHAccel" Grid.Row="7" Grid.Column="0" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtHAccel" Grid.Row="7" Grid.Column="1" Margin="0,0,0,10"
                             PreviewTextInput="NumericOnly" DataObject.Pasting="OnPasteNumeric"/>
                </Grid>

                <CheckBox x:Name="ChkEasing" Margin="0,6,0,0"/>
                <CheckBox x:Name="ChkMomentum" Margin="0,10,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtLblFriction" Grid.Column="0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Slider x:Name="SldFriction" Minimum="0" Maximum="100" Width="104" VerticalAlignment="Center"
                                IsEnabled="{Binding IsChecked, ElementName=ChkMomentum}" ValueChanged="OnFrictionChanged"/>
                        <TextBlock x:Name="TxtFrictionVal" Margin="10,0,0,0" MinWidth="24" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtLblFlick" Grid.Column="0" TextWrapping="Wrap"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Slider x:Name="SldFlick" Minimum="0" Maximum="5000" Width="104" VerticalAlignment="Center"
                                IsEnabled="{Binding IsChecked, ElementName=ChkMomentum}" ValueChanged="OnFlickChanged"/>
                        <TextBlock x:Name="TxtFlickVal" Margin="10,0,0,0" MinWidth="36" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Button x:Name="BtnReset" Click="OnResetClick" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Click="OnCancelClick" Margin="0,0,8,0"/>
                <Button x:Name="BtnSave" Click="OnSaveClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
